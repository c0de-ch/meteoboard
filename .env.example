# =============================================================================
# MeteoBoard Configuration
# =============================================================================
# Copy this file to .env and edit the values for your setup.
# Run `npm run setup` for guided configuration.
# =============================================================================

# MQTT Broker Connection
# The URL of your MQTT broker (where the Shelly BLU Gateway publishes data)
MQTT_BROKER_URL=mqtt://192.168.1.100:1883

# MQTT Topic Prefix
# The Shelly BLU Gateway's device ID or custom MQTT prefix.
# Find it in the gateway's web UI under Settings > MQTT, or run `npm run discover`.
# Example: shellyblugwg3-AABBCCDDEEFF
MQTT_TOPIC_PREFIX=shellyblugwg3-XXXXXXXXXXXX

# Sensor Component ID Mapping
# Maps sensor names to BTHomeSensor component IDs assigned by your gateway.
# These IDs are unique to YOUR installation. Run `npm run discover` to find them.
# Format: name1=id1,name2=id2,...
SENSOR_MAP=temperature=213,humidity=214,pressure=216,illuminance=207,dew_point=215,wind_speed=209,wind_gust=210,uv_index=211,wind_direction=212,precipitation=218,rain_status=208

# BTHomeDevice ID (for battery level and RSSI signal strength)
DEVICE_ID=202

# Dashboard Server
PORT=3000
HOST=0.0.0.0

# Database Path (relative to project root)
DB_PATH=./data/meteoboard.db

# Data Retention
# Raw sensor data is kept for this many days (high resolution, ~8.8s intervals)
DATA_RETENTION_DAYS=30
# Hourly aggregates are kept for this many days (min/avg/max per hour)
AGGREGATE_RETENTION_DAYS=365
